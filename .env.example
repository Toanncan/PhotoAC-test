# ============================================================
# Environment Configuration — DO NOT COMMIT THE ACTUAL .env FILE
# Copy this file to .env and fill in your actual values
# ============================================================

# Application URL
BASE_URL=https://test-lien.photo-ac.com

# HTTP Basic Auth for staging server (popup credentials when first accessing)
HTTP_USER=your-http-username
HTTP_PASS=your-http-password

# Test User Credentials (Download member)
TEST_USER_EMAIL=your-email@example.com
TEST_USER_PASSWORD=your-password

# Creator Credentials
CREATOR_EMAIL=your-creator-email@example.com
CREATOR_PASSWORD=your-creator-password

# Admin Credentials (if applicable)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin-password

# Environment (local | staging | production)
ENV=staging

# Allure Report Settings (optional)
ALLURE_RESULTS_DIR=allure-results
